# ─── Auth ───
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ─── Required for non-Vercel hosts (Netlify, Railway, etc.) ───
AUTH_TRUST_HOST=true
AUTH_URL=http://localhost:3000

# ─── Admin ───
ADMIN_GITHUB_IDS=

# ─── GitHub PR Bot ───
# Personal access token with 'repo' scope
# PRs are created on rootdb-xyz/data
# Leave empty to disable auto-PR (submissions save to store only)
GITHUB_BOT_TOKEN=

# ─── Features ───
NEXT_PUBLIC_ENABLE_AFFILIATES=
NEXT_PUBLIC_ENABLE_SUPPORT_BANNER=